# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co        # REQUIRED
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here                    # reserved — future browser-side client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here                # REQUIRED — server-only, NEVER expose to browser

# ─── Resend (email) ──────────────────────────────────────────────────────────
# Found in: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Slack notifications ─────────────────────────────────────────────────────
# Create an incoming webhook at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ─── Cal.com ─────────────────────────────────────────────────────────────────
# Found in: Cal.com Dashboard → Settings → Developer → Webhooks → Secret
CALCOM_WEBHOOK_SECRET=your-calcom-webhook-secret-here               # REQUIRED — webhook will return 500 if missing

# ─── AI / Chatbot (Groq — powers the chat widget with Llama 3.3 70B) ─────────
# Get your free key at: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx                           # REQUIRED — falls back to keyword stub if missing

# ─── Cal.com ─────────────────────────────────────────────────────────────────
# Your Cal.com event link slug (e.g. yourname/discovery-call)
# Found in: Cal.com Dashboard → Event Types → Share
NEXT_PUBLIC_CALCOM_LINK=charlesshalua/discovery-call

# ─── Site URL (used for sitemap generation) ──────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ─── ChromaDB (optional — for future RAG upgrade) ────────────────────────────
CHROMA_URL=http://localhost:8000
